# Optional vault target. If unset, contents-hub uses the current directory.
CONTENTS_HUB_VAULT=/path/to/contents-vault

# Runtime-neutral default. Set to claude-sdk only when the Claude extra is
# installed and agent-backed collection or synthesis is desired.
CONTENTS_HUB_AGENT_RUNNER=none

# Optional limit for agent tool result compaction.
CONTENTS_HUB_AGENT_TOOL_RESULT_MAX_CHARS=35000
